# Discord
DISCORD_TOKEN=                # Bot-Token dieses Agenten
DISCORD_CHANNEL_ID=           # ID des Spielkanals

# LLM
LLM_MODEL=                    # z.B. claude-sonnet-4-6
LLM_PROVIDER=                 # anthropic | openai | gemini | groq | mistral | hub

# AI HUB (wenn LLM_PROVIDER_DM=hub)
AI_HUB_URL=your_hub_url_here
AI_HUB_TOKEN=your_hub_token_here

# DIREKTE ANBIETER (wenn LLM_PROVIDER_DM=anthropic)
ANTHROPIC_API_KEY=your_anthropic_key_here

# DIREKTE ANBIETER (wenn LLM_PROVIDER_DM=openai)
OPENAI_API_KEY=your_openai_key_here

# DIREKTE ANBIETER (wenn LLM_PROVIDER_DM=groq)
GROQ_API_KEY=your_groq_key_here

# DIREKTE ANBIETER (wenn LLM_PROVIDER_DM=mistral)
MISTRAL_API_KEY=your_mistral_key_here

# DIREKTE ANBIETER (wenn LLM_PROVIDER_DM=gemini)
GEMINI_API_KEY=your_gemini_key_here

# Optional
POLL_INTERVAL=5
